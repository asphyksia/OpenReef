# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5444/openreef

# Redis
REDIS_URL=redis://127.0.0.1:6379/0

# Auth
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=4320

# Cloudflare R2 (future)
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=openreef-mvp

# Stripe (for dev, set placeholder to enable dev credits mode)
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# OGPU adapter: mock (local dev) or real (production)
OGPU_ADAPTER=mock

# OGPU Network (only needed when OGPU_ADAPTER=real)
CLIENT_PRIVATE_KEY=
OGPU_SOURCE_ADDRESS=
OGPU_USE_TESTNET=true

# App URLs
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:8000

# Flower (Celery monitor) — CHANGE these for production
FLOWER_USER=admin
FLOWER_PASSWORD=change-me-in-production
